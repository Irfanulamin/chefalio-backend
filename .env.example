# --------------------------------------------------
# Application Environment
# Set the running environment of the app
# Example: development | production
NODE_ENV=

# Port where the backend server will run
# Example: 5000
PORT=

# --------------------------------------------------
# Database Configuration
# MongoDB connection string
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=

# --------------------------------------------------
# Authentication
# Secret key used to sign JWT tokens
# Generate a long random string for security
JWT_SECRET=

# --------------------------------------------------
# Cloudinary (Image Upload Service)
# Get these values from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --------------------------------------------------
# Password Reset
# Frontend URL where users will be redirected to reset password
# Example: http://localhost:3000/reset-password
RESET_PASSWORD_URL=
# Frontend URL for CORS and email links
FRONTEND_URL=
# Allowed origin for CORS in production
ALLOWED_ORIGIN=

# --------------------------------------------------
# Email Service (SMTP)
# Email address used to send system emails
EMAIL_USER=

# App password or SMTP password for the email account
EMAIL_PASS=

# --------------------------------------------------
# Resend Email API
# API key from https://resend.com for sending emails
RESEND_API_KEY=

# --------------------------------------------------
# Stripe Payment Gateway
# Secret key from your Stripe dashboard
STRIPE_SECRET_KEY=
# Webhook secret for verifying Stripe webhooks
STRIPE_WEBHOOK_SECRET=